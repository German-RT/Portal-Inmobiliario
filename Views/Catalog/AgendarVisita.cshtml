@model PortalInmobiliario.Models.AgendarVisitaViewModel

@{
    ViewData["Title"] = "Agendar Visita";
}

<div class="container mt-4">
    <h2>Agendar Visita</h2>
    <h4>@Model.InmuebleTitulo</h4>

    <div class="row">
        <div class="col-md-6">
            <form asp-action="AgendarVisita" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                <input type="hidden" asp-for="InmuebleId" />
                <input type="hidden" asp-for="InmuebleTitulo" />

                <div class="mb-3">
                    <label asp-for="FechaInicio" class="form-label"></label>
                    <input asp-for="FechaInicio" class="form-control" />
                    <span asp-validation-for="FechaInicio" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="FechaFin" class="form-label"></label>
                    <input asp-for="FechaFin" class="form-control" />
                    <span asp-validation-for="FechaFin" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Notas" class="form-label"></label>
                    <textarea asp-for="Notas" class="form-control" rows="4" 
                              placeholder="Información adicional, preguntas, etc."></textarea>
                    <span asp-validation-for="Notas" class="text-danger"></span>
                </div>

                <div class="alert alert-info">
                    <strong>Horario laboral:</strong> 08:00 - 19:00<br>
                    <strong>Duración máxima:</strong> 2 horas por visita
                </div>

                <div class="d-grid gap-2">
                    <button type="submit" class="btn btn-success">Confirmar Visita</button>
                    <a href="@Url.Action("Details", new { id = Model.InmuebleId })" class="btn btn-secondary">Cancelar</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}